## ── .NET / ASP.NET Core ──────────────────────────────────────────────────────
# Build output
bin/
obj/
out/
build-output/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/repositories.config

# User-specific files
*.user
*.suo
*.userosscache
*.sln.docstates
.vs/

# Publish output
publish/
**/publish/

# Runtime / logs — only the app's runtime log output directory, NOT Views/Logs
/LetterTemplatePractice/Logs/*
!/LetterTemplatePractice/Logs/.gitkeep
*.log
*.trn

# Secrets — NEVER commit these
appsettings.Development.json
appsettings.*.json
!appsettings.json

# dotnet user secrets
secrets.json

## ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

## ── IDEs ─────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

## ── Node (if any frontend tooling) ──────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*

## ── Uploads (user content — don't commit actual files) ──────────────────────
LetterTemplatePractice/wwwroot/uploads/*
!LetterTemplatePractice/wwwroot/uploads/.gitkeep

## ── dotnet sentinel / telemetry files ───────────────────────────────────────
.dotnet/

## ── React build output ───────────────────────────────────────────────────────
UIForm/dist/