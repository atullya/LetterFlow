@model LetterTemplatePractice.Models.ViewModels.HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
    var activeTab = Context.Request.Query["tab"].ToString();
    if (string.IsNullOrEmpty(activeTab)) activeTab = "foryou";
    var search = Context.Request.Query["search"].ToString();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="margin-bottom:16px;">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
<div class="feed-layout">
    <main class="feed-main">

        <!-- Search bar -->
        <section class="feed-filter-bar">
            <form method="get" asp-controller="Blog" asp-action="Explore" class="feed-filter-form" id="homeSearchForm">
                <div class="explore-search-wrap">
                    <i class="fas fa-search explore-search-icon"></i>
                    <input type="text" name="search" id="homeSearchInput" class="form-control explore-search-input"
                           value="@search" placeholder="Search stories…" autocomplete="off" />
                    <span class="explore-search-spinner" id="homeSearchSpinner" style="display:none;">
                        <i class="fas fa-circle-notch fa-spin"></i>
                    </span>
                </div>
            </form>
        </section>

        <!-- For you / Featured tabs -->
        <div class="feed-tabs" id="homeTabs">
            <a href="?tab=foryou"   class="feed-tab @(activeTab == "foryou"   ? "active" : "")">For you</a>
            <a href="?tab=featured" class="feed-tab @(activeTab == "featured" ? "active" : "")">Featured</a>
        </div>

        <section class="story-list" id="homeStoryList">
            @{
                var posts = activeTab == "featured"
                    ? Model.FeaturedPosts
                    : Model.LatestPosts;
            }
            @foreach (var post in posts)
            {
                await Html.RenderPartialAsync("_StoryCard", post);
            }
        </section>
    </main>

    <aside class="feed-rail">
        @if (Model.PopularPosts.Any())
        {
            <section class="rail-section">
                <h2>Staff Picks</h2>
                <div class="stack-sm">
                    @foreach (var post in Model.PopularPosts)
                    {
                        <div class="staff-pick">
                            <div class="staff-pick-author">
                                <div class="sc-avatar sc-avatar-sm">
                                    @if (!string.IsNullOrEmpty(post.Author?.AvatarUrl))
                                    {
                                        <img src="@post.Author.AvatarUrl" alt="" />
                                    }
                                    else
                                    {
                                        <span>@((post.Author?.DisplayName ?? post.Author?.Username ?? "?").Substring(0,1).ToUpper())</span>
                                    }
                                </div>
                                <span>@(post.Author?.DisplayName ?? post.Author?.Username)</span>
                            </div>
                            <a asp-controller="Blog" asp-action="Details" asp-route-slug="@post.Slug" class="compact-story-link">
                                <div class="compact-story-title">@post.Title</div>
                            </a>
                            <div class="compact-story-meta">
                                @(post.PublishedAt?.ToString("MMM d") ?? post.UpdatedAt.ToString("MMM d"))
                            </div>
                        </div>
                    }
                </div>
                <a asp-controller="Blog" asp-action="Explore" class="rail-see-all">See the full list</a>
            </section>
        }

        @if (Model.Topics.Any())
        {
            <section class="rail-section">
                <h2>Recommended topics</h2>
                <div class="topic-pills">
                    @foreach (var topic in Model.Topics)
                    {
                        <a asp-controller="Blog" asp-action="Explore" asp-route-topic="@topic" class="topic-pill">@topic</a>
                    }
                </div>
            </section>
        }

        <section class="rail-section rail-stats">
            <h2>Publication</h2>
            <div class="rail-stat"><strong>@Model.PublishedPostCount</strong><span>published stories</span></div>
            <div class="rail-stat"><strong>@Model.WriterCount</strong><span>writers</span></div>
            <div class="rail-stat"><strong>@Model.CommentCount</strong><span>reader comments</span></div>
        </section>
    </aside>
</div>

@section Scripts {
<style>
.explore-search-wrap {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
}
.explore-search-icon {
    position: absolute;
    left: 12px;
    color: var(--muted);
    font-size: 0.82rem;
    pointer-events: none;
    z-index: 1;
}
.explore-search-input {
    padding-left: 34px !important;
    padding-right: 36px !important;
}
.explore-search-spinner {
    position: absolute;
    right: 12px;
    color: var(--muted);
    font-size: 0.82rem;
}
/* Hide tabs while searching */
#homeTabs.searching { display: none; }
</style>

<script>
(function () {
    const input     = document.getElementById('homeSearchInput');
    const storyList = document.getElementById('homeStoryList');
    const spinner   = document.getElementById('homeSearchSpinner');
    const tabs      = document.getElementById('homeTabs');
    if (!input || !storyList) return;

    let debounceTimer;
    let currentController;

    async function fetchResults(term) {
        if (currentController) currentController.abort();
        currentController = new AbortController();
        spinner.style.display = '';

        try {
            const url = '/Blog/Explore?' + new URLSearchParams({ search: term });
            const res = await fetch(url, {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                signal: currentController.signal
            });
            if (!res.ok) return;
            storyList.innerHTML = await res.text();
        } catch (e) {
            if (e.name !== 'AbortError') console.error(e);
        } finally {
            spinner.style.display = 'none';
        }
    }

    function restoreHome() {
        // Reload the page to restore the original For You / Featured feed
        window.location.href = '/';
    }

    input.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        const term = this.value.trim();

        if (!term) {
            // Empty — restore original feed without reload by showing cached content
            tabs.classList.remove('searching');
            debounceTimer = setTimeout(restoreHome, 600);
            return;
        }

        tabs.classList.add('searching');
        debounceTimer = setTimeout(() => fetchResults(term), 350);
    });
})();
</script>
}

