@{
    ViewData["Title"] = "Privacy";
}

<div class="page-header">
    <div class="page-header-left">
        <div class="eyebrow">
            <i class="fas fa-shield-heart"></i>
            Publication policy
        </div>
        <h1>Privacy and platform notes</h1>
        <p>How reader accounts, published stories, comments, and local application data are handled in this workspace.</p>
    </div>
</div>

<div class="blog-home-grid">
    <section class="workspace-panel">
        <div class="stack-sm" style="line-height:1.8">
            <div>
                <h2 class="section-title">Accounts</h2>
                <p class="section-copy">Usernames and emails are stored locally so writers can sign in, publish stories, and interact with posts. Passwords remain hashed and are never stored in plain text.</p>
            </div>
            <div>
                <h2 class="section-title">Stories and comments</h2>
                <p class="section-copy">Published stories and comments are visible to readers inside this application. Draft stories remain private to their authors and administrators.</p>
            </div>
            <div>
                <h2 class="section-title">Operational logs</h2>
                <p class="section-copy">Application logs are kept for support and debugging. The logs screen now focuses on warnings and errors rather than routine info noise.</p>
            </div>
        </div>
    </section>

    <aside class="workspace-panel">
        <div class="eyebrow">
            <i class="fas fa-lock"></i>
            Local-first
        </div>
        <p class="section-copy">This project runs against your configured local database and application environment. Sharing outward only happens when a user explicitly copies a story link or publishes content to readers inside the app.</p>
    </aside>
</div>
