@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div style="display:flex;align-items:center;justify-content:center;min-height:60vh">
    <div style="text-align:center;max-width:480px">
        <div style="font-size:4rem;color:var(--danger);margin-bottom:16px">
            <i class="fas fa-exclamation-circle"></i>
        </div>
        <h2 style="font-weight:700;margin-bottom:8px">Something went wrong</h2>
        <p style="color:var(--text-muted);margin-bottom:24px">An error occurred while processing your request.</p>

        @if (Model?.ShowRequestId == true)
        {
            <div class="alert alert-danger" style="text-align:left;font-size:.8rem">
                <strong>Request ID:</strong> <code>@Model.RequestId</code>
            </div>
        }

        <a href="/" class="btn btn-primary">
            <i class="fas fa-home"></i> Back to Dashboard
        </a>
    </div>
</div>
