@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Home";
    var metaDescriptionRaw = ViewData["MetaDescription"]?.ToString()
        ?? "LetterFlow Stories is a professional newsletter platform to read, write, and publish stories with ease.";
    var metaDescription = metaDescriptionRaw.Length > 160
        ? metaDescriptionRaw[..157].TrimEnd() + "..."
        : metaDescriptionRaw;
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
    var ogImagePath = ViewData["OgImage"]?.ToString() ?? "/images/og-default.jpg";
    var ogImageUrl = ogImagePath.StartsWith("http", StringComparison.OrdinalIgnoreCase)
        ? ogImagePath
        : $"{Context.Request.Scheme}://{Context.Request.Host}{Url.Content($"~{ogImagePath}")}";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - LetterFlow Stories</title>
    <meta name="description" content="@metaDescription" />
    <link rel="canonical" href="@canonicalUrl" />
    <meta property="og:title" content="@pageTitle - LetterFlow Stories" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:image" content="@ogImageUrl" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="LetterFlow Stories" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@pageTitle - LetterFlow Stories" />
    <meta name="twitter:description" content="@metaDescription" />
    <meta name="twitter:image" content="@ogImageUrl" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='22' fill='%23242424'/><text y='.9em' font-size='48' x='16' fill='white'>LF</text></svg>" />
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;800&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/LetterTemplatePractice.styles.css" asp-append-version="true" />
    <script>
        // Restore sidebar state before first paint to prevent slide-in animation on navigation.
        if (sessionStorage.getItem('sidebarOpen') === '1') {
            document.documentElement.classList.add('sidebar-preopen');
        }
    </script>
</head>
@{
    string? _avatarUrl = null;
    string _displayName = User.Identity?.Name ?? "?";
    string? _username = null;
    string _emailRaw = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
    string _emailMasked = _emailRaw;

    if (User.Identity?.IsAuthenticated == true)
    {
        var _authSvc = Context.RequestServices.GetRequiredService<LetterTemplatePractice.Auth.IAuthService>();
        var _uidStr  = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (_uidStr != null && int.TryParse(_uidStr, out var _uid))
        {
            var _cu = await _authSvc.GetUserByIdAsync(_uid);
            _avatarUrl   = _cu?.AvatarUrl;
            _displayName = _cu?.DisplayName ?? _cu?.Username ?? _displayName;
            _username    = _cu?.Username;
        }
        if (_emailRaw.Contains('@'))
        {
            int _at = _emailRaw.IndexOf('@');
            _emailMasked = _emailRaw[0] + new string('*', Math.Min(6, _at - 1)) + _emailRaw[_at..];
        }
    }
}
<body class="@(ViewData["BodyClass"] ?? string.Empty)">
<div class="reading-progress" id="readingProgress" aria-hidden="true"></div>
<div class="app-shell">

    <!-- Sidebar: hidden by default, toggled by hamburger -->
    <aside class="sidebar" id="sidebar">
        <nav class="sidebar-nav">
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
               asp-controller="Home" asp-action="Index">
                <i class="fas fa-house"></i>
                <span>Home</span>
            </a>
            <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" && ViewContext.RouteData.Values["action"]?.ToString() == "Explore" ? "active" : "")"
               asp-controller="Blog" asp-action="Explore">
                <i class="fas fa-compass"></i>
                <span>Explore</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" && ViewContext.RouteData.Values["action"]?.ToString() == "Create" ? "active" : "")"
                   asp-controller="Blog" asp-action="Create">
                    <i class="fas fa-pen"></i>
                    <span>Write</span>
                </a>
                <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Blog" && ViewContext.RouteData.Values["action"]?.ToString() == "Mine" ? "active" : "")"
                   asp-controller="Blog" asp-action="Mine">
                    <i class="fas fa-book-open"></i>
                    <span>My Stories</span>
                </a>
            }
            @* <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Privacy" ? "active" : "")"
               asp-controller="Home" asp-action="Privacy">
                <i class="fas fa-shield-heart"></i>
                <span>Privacy</span>
            </a> *@
            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.IsInRole("Admin"))
                {
                    <div class="sidebar-section-divider"></div>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "active" : "")"
                       asp-controller="Logs" asp-action="Index">
                        <i class="fas fa-terminal"></i>
                        <span>Logs</span>
                    </a>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AiDashboard" ? "active" : "")"
                       asp-controller="AiDashboard" asp-action="Index">
                        <i class="fas fa-robot"></i>
                        <span>AI Dashboard</span>
                    </a>
                }
            }
        </nav>
    </aside>

    <div class="shell-backdrop" id="shellBackdrop"></div>

    <header class="topbar">
        <div class="topbar-intro">
            <!-- Hamburger: always visible, toggles sidebar -->
            <button class="topbar-hamburger" id="sidebarToggle" type="button" aria-label="Toggle navigation">
                <span></span><span></span><span></span>
            </button>
            <a class="topbar-home-link" asp-controller="Home" asp-action="Index">
                <span class="topbar-logo-mark"><i class="fas fa-feather-pointed"></i></span>
                <span class="topbar-wordmark">LetterFlow Stories</span>
            </a>
        </div>

        <div class="topbar-actions">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Blog" asp-action="Create" class="topbar-write-btn">
                    <i class="fas fa-pen-to-square"></i>
                    <span>Write</span>
                </a>
                <div class="notification-wrapper" id="notificationRoot">
                    <button class="topbar-icon-btn" id="notificationToggle" title="Notifications" aria-label="Notifications" type="button">
                        <i class="fas fa-bell"></i>
                        <span class="notification-badge" id="notificationBadge" style="display:none;">0</span>
                    </button>
                    <div class="notification-dropdown" id="notificationDropdown">
                        <div class="notification-dropdown-header">
                            <span style="font-weight:700;">Notifications</span>
                            <button type="button" class="notification-mark-read" id="markAllReadBtn">Mark all as read</button>
                        </div>
                        <div class="notification-list" id="notificationList">
                            <div class="notification-empty" id="notificationEmpty">
                                <i class="fa-regular fa-bell"></i>
                                <div>No notifications yet</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="topbar-user-menu" id="userMenuRoot">
                    <button class="topbar-avatar-btn" id="userMenuToggle" type="button"
                            aria-haspopup="true" aria-expanded="false">
                        @if (!string.IsNullOrEmpty(_avatarUrl))
                        {
                            <img src="@_avatarUrl" alt="@_displayName" class="topbar-avatar-img" />
                        }
                        else
                        {
                            <span class="topbar-avatar-initials">@(_displayName.Substring(0, 1).ToUpper())</span>
                        }
                    </button>
                    <div class="user-dropdown" id="userDropdown" role="menu">
                        <div class="user-dropdown-header">
                            <div class="user-dropdown-avatar">
                                @if (!string.IsNullOrEmpty(_avatarUrl))
                                {
                                    <img src="@_avatarUrl" alt="@_displayName" />
                                }
                                else
                                {
                                    <span>@(_displayName.Substring(0, 1).ToUpper())</span>
                                }
                            </div>
                            <div class="user-dropdown-info">
                                <span class="user-dropdown-name">@_displayName</span>
                                <a href="/@@@(_username)" class="user-dropdown-profile-link">View profile</a>
                            </div>
                        </div>
                        <div class="user-dropdown-divider"></div>
                        <a asp-controller="Settings" asp-action="Index" class="user-dropdown-item" role="menuitem">
                            <i class="fas fa-gear"></i> Settings
                        </a>
                        <a href="#" class="user-dropdown-item" role="menuitem">
                            <i class="fas fa-circle-question"></i> Help
                        </a>
                        <div class="user-dropdown-divider"></div>
                        <div class="user-dropdown-footer">
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="user-dropdown-logout">Logout</button>
                            </form>
                            <span class="user-dropdown-email">@_emailMasked</span>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="btn btn-secondary btn-sm">Sign in</a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Get started</a>
            }
        </div>
    </header>

    <div class="main-content" id="mainContent">
        <div class="page-body">
            @RenderBody()
        </div>
    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
