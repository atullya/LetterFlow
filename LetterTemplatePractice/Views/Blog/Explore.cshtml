@model IReadOnlyList<LetterTemplatePractice.Models.BlogPost>
@{
    ViewData["Title"] = "Explore";
    ViewData["HideNavSearch"] = true;   // suppress the duplicate navbar search bar
    var topic  = ViewBag.Topic  as string;
    var search = ViewBag.Search as string;
    var topics = ViewBag.Topics as IReadOnlyList<string> ?? [];
}

<div class="feed-layout">
    <main class="feed-main">
        <section class="feed-filter-bar">
            <form method="get" asp-action="Explore" class="feed-filter-form" id="exploreForm">
                <div class="explore-search-wrap">
                    <i class="fas fa-search explore-search-icon"></i>
                    <input type="text" name="search" id="searchInput" class="form-control explore-search-input"
                           value="@search" placeholder="Search stories…" autocomplete="off" />
                    <span class="explore-search-spinner" id="searchSpinner" style="display:none;">
                        <i class="fas fa-circle-notch fa-spin"></i>
                    </span>
                </div>
                <select name="topic" id="topicSelect" class="form-select">
                    <option value="">All topics</option>
                    @foreach (var t in topics)
                    {
                        <option value="@t" selected="@(string.Equals(topic, t, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">
                            @t
                        </option>
                    }
                </select>
                <button type="submit" class="btn btn-primary">Apply</button>
                <a asp-action="Explore" class="btn btn-secondary">Reset</a>
            </form>
        </section>

        <section class="story-list" id="storyList">
            @await Html.PartialAsync("_ExploreResults", Model)
        </section>
    </main>

    <aside class="feed-rail">
        @if (topics.Any())
        {
            <section class="rail-section">
                <h2>Browse by topic</h2>
                <div class="topic-pills">
                    @foreach (var t in topics)
                    {
                        <a asp-action="Explore" asp-route-topic="@t"
                           class="topic-pill @(string.Equals(topic, t, StringComparison.OrdinalIgnoreCase) ? "topic-pill-active" : "")">@t</a>
                    }
                </div>
            </section>
        }

        @if (Model.Any())
        {
            <section class="rail-section">
                <h2>In this list</h2>
                <div class="stack-sm">
                    @foreach (var post in Model.Take(5))
                    {
                        <a asp-action="Details" asp-route-slug="@post.Slug" class="compact-story-link">
                            <div class="compact-story-title">@post.Title</div>
                            <div class="compact-story-meta">
                                @(post.Author?.DisplayName ?? post.Author?.Username) · @post.ReadTimeMinutes min read
                            </div>
                        </a>
                    }
                </div>
            </section>
        }
    </aside>
</div>

@section Scripts {
<style>
.explore-search-wrap {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
}

.explore-search-icon {
    position: absolute;
    left: 12px;
    color: var(--muted);
    font-size: 0.82rem;
    pointer-events: none;
    z-index: 1;
}

.explore-search-input {
    padding-left: 34px !important;
    padding-right: 36px !important;
}

.explore-search-spinner {
    position: absolute;
    right: 12px;
    color: var(--muted);
    font-size: 0.82rem;
}
</style>

<script>
(function () {
    const searchInput = document.getElementById('searchInput');
    const topicSelect = document.getElementById('topicSelect');
    const storyList   = document.getElementById('storyList');
    const spinner     = document.getElementById('searchSpinner');
    if (!searchInput || !storyList) return;

    let debounceTimer;
    let currentController; // AbortController for in-flight requests

    function buildUrl() {
        const params = new URLSearchParams();
        const s = searchInput.value.trim();
        const t = topicSelect?.value ?? '';
        if (s) params.set('search', s);
        if (t) params.set('topic', t);
        return '/Blog/Explore?' + params.toString();
    }

    async function fetchResults() {
        // Cancel any previous in-flight request
        if (currentController) currentController.abort();
        currentController = new AbortController();

        spinner.style.display = '';

        try {
            const res = await fetch(buildUrl(), {
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                signal: currentController.signal
            });
            if (!res.ok) return;
            const html = await res.text();
            storyList.innerHTML = html;
        } catch (e) {
            if (e.name !== 'AbortError') console.error(e);
        } finally {
            spinner.style.display = 'none';
        }
    }

    // Debounced input — fires 350ms after user stops typing, focus never leaves the field
    searchInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(fetchResults, 350);
    });

    // Topic dropdown — instant
    topicSelect?.addEventListener('change', function () {
        clearTimeout(debounceTimer);
        fetchResults();
    });
})();
</script>
}
