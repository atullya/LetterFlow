@model LetterTemplatePractice.Models.ViewModels.BlogComposerViewModel
@{
    ViewData["Title"]    = Model.Id.HasValue ? "Edit Story" : "Write Story";
    ViewData["BodyClass"] = "editor-page";
    var isEditing = Model.Id.HasValue;
    var notebooks = ViewBag.NotebookOptions as IReadOnlyList<LetterTemplatePractice.Models.Notebook>
                    ?? new List<LetterTemplatePractice.Models.Notebook>();
}

<div class="editor-shell-wrap">

    
    <div class="editor-topbar">
        <a asp-action="Mine" class="editor-back-link">
            <i class="fas fa-arrow-left"></i>
            <span>My Stories</span>
        </a>
        <span class="editor-topbar-title">@(isEditing ? "Editing story" : "New story")</span>
        <span class="editor-draft-indicator" id="draftIndicator"></span>
        <div class="editor-topbar-actions">
            <button type="submit" form="editorForm" name="SubmitAction" value="draft" class="btn btn-secondary btn-sm">
                <i class="fas fa-floppy-disk"></i> Save Draft
            </button>
            <button type="submit" form="editorForm" name="SubmitAction" value="publish" class="btn btn-primary btn-sm">
                <i class="fas fa-rocket"></i>
                @(Model.IsPublished ? "Update" : "Publish")
            </button>
        </div>
    </div>

    <form id="editorForm" asp-action="@(isEditing ? "Edit" : "Create")" asp-route-id="@Model.Id" method="post">
        @Html.AntiForgeryToken()

        <div class="editor-layout">

        
            <div class="editor-canvas">

                <div asp-validation-summary="ModelOnly" class="editor-validation"></div>

                <div class="editor-field-title">
                    <input asp-for="Title"
                           class="editor-input-title"
                           placeholder="Title"
                           autocomplete="off" />
                    <span asp-validation-for="Title" class="editor-field-error"></span>
                </div>

                <div class="editor-field-subtitle">
                    <input asp-for="Subtitle"
                           class="editor-input-subtitle"
                           placeholder="Add a subtitle…"
                           autocomplete="off" />
                </div>

                <div class="editor-meta-row">
                    <div class="editor-meta-field">
                        <label class="editor-meta-label">Topic</label>
                        <input asp-for="Topic" id="Topic" class="editor-meta-input" placeholder="e.g. Design, Engineering" />
                    </div>
                    <div class="editor-meta-field">
                        <label class="editor-meta-label">Notebook</label>
                        <select asp-for="NotebookId" class="editor-meta-input">
                            <option value="">No notebook</option>
                            @foreach (var notebook in notebooks)
                            {
                                <option value="@notebook.Id">@notebook.Name</option>
                            }
                        </select>
                    </div>
                    <div class="editor-meta-field">
                        <label class="editor-meta-label">Cover Image URL</label>
                        <input asp-for="CoverImageUrl" class="editor-meta-input" placeholder="https://…" />
                        <span asp-validation-for="CoverImageUrl" class="editor-field-error"></span>
                    </div>
                    <div class="editor-meta-field editor-meta-field--wide">
                        <label class="editor-meta-label">Excerpt <span class="editor-meta-hint">— shown in feed cards</span></label>
                        <input asp-for="Excerpt" id="Excerpt" class="editor-meta-input" placeholder="A short summary for previews…" />
                    </div>
                    @if (User.IsInRole(UserRoles.Admin))
                    {
                        <div class="editor-meta-field editor-meta-field--check">
                            <label class="editor-check-label">
                                <input asp-for="IsFeatured" type="checkbox" class="editor-check-input" />
                                <span>Feature on home page</span>
                            </label>
                        </div>
                    }
                </div>

                <div class="editor-divider"></div>

                <div class="editor-content-field">
                    <textarea asp-for="ContentHtml" id="storyEditor"></textarea>
                    <span asp-validation-for="ContentHtml" class="editor-field-error"></span>
                </div>

            </div>

    
            <aside class="ai-sidebar">
                <div class="ai-panel">
                    <div class="ai-panel-header">
                        <i class="fas fa-wand-magic-sparkles"></i>
                        AI Assistant
                    </div>
                    <div class="ai-actions">
                        <button type="button" id="btnImprove" class="ai-btn">
                            <i class="fas fa-pen-nib"></i> Improve selected
                        </button>
                        <button type="button" id="btnContinue" class="ai-btn">
                            <i class="fas fa-forward"></i> Continue writing
                        </button>
                        <button type="button" id="btnSummarize" class="ai-btn">
                            <i class="fas fa-align-left"></i> Auto-fill excerpt
                        </button>
                        <button type="button" id="btnSuggestTitle" class="ai-btn">
                            <i class="fas fa-heading"></i> Suggest titles
                        </button>
                        <button type="button" id="btnSuggestTags" class="ai-btn">
                            <i class="fas fa-tags"></i> Suggest tags
                        </button>
                        <button type="button" id="btnSuggestImages" class="ai-btn">
                            <i class="fas fa-image"></i> Suggest cover image
                        </button>
                    </div>

                    <div class="ai-spinner" id="aiSpinner">
                        <i class="fas fa-circle-notch ai-spin-icon"></i>
                        Thinking…
                    </div>

                    <div class="ai-result" id="aiResult">
                        <div id="aiResultText"></div>
                        <div class="ai-result-actions">
                            <button type="button" id="btnApplyImprove" class="ai-btn ai-btn-primary" style="display:none">
                                <i class="fas fa-check"></i> Apply
                            </button>
                            <button type="button" id="btnApplyContinue" class="ai-btn ai-btn-primary" style="display:none">
                                <i class="fas fa-plus"></i> Append
                            </button>
                            <button type="button" class="ai-btn" onclick="document.getElementById('aiResult').classList.remove('visible')">
                                <i class="fas fa-times"></i> Dismiss
                            </button>
                        </div>
                    </div>

                    <div class="ai-title-chips" id="aiTitleChips"></div>
                    <div class="ai-tag-chips" id="aiTagChips"></div>

                    <div class="ai-image-section" id="aiImageSection" style="display:none">
                        <div class="ai-image-label" id="aiImageLabel"></div>
                        <div class="ai-image-grid" id="aiImageGrid"></div>
                    </div>

                  
                </div>
            </aside>

        </div>
    </form>

</div>

@section Scripts {
<style>
/* ── Editor page ─────────────────────────────────────────────── */
.editor-page .page-body { padding: 0; }

.editor-shell-wrap {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - var(--topbar-h));
}

/* Sticky topbar */
.editor-topbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 0 32px;
    height: 52px;
    border-bottom: 1px solid var(--line);
    background: #fff;
    position: sticky;
    top: var(--topbar-h);
    z-index: 100;
    flex-shrink: 0;
}

.editor-back-link {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 0.85rem; color: var(--muted); text-decoration: none;
    transition: color 160ms ease; flex-shrink: 0;
}
.editor-back-link:hover { color: var(--text); text-decoration: none; }

.editor-topbar-title {
    font-size: 0.82rem; color: var(--muted);
    flex: 1; text-align: center;
}

.editor-draft-indicator {
    font-size: 0.75rem;
    color: var(--muted);
    opacity: 0;
    transition: opacity 400ms ease;
    white-space: nowrap;
    flex-shrink: 0;
}
.editor-draft-indicator.visible { opacity: 1; }

.editor-topbar-actions { display: flex; gap: 8px; flex-shrink: 0; }

/* ── Two-column layout ───────────────────────────────────────── */
.editor-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 0;
    flex: 1;
    align-items: start;
}

/* Writing canvas */
.editor-canvas {
    padding: 40px 48px 60px 64px;
    border-right: 1px solid var(--line);
    min-width: 0;
}

/* AI sidebar */
.ai-sidebar {
    padding: 24px 20px;
    position: sticky;
    top: calc(var(--topbar-h) + 52px);
    max-height: calc(100vh - var(--topbar-h) - 52px);
    overflow-y: auto;
    scrollbar-width: none;
}
.ai-sidebar::-webkit-scrollbar { display: none; }

/* ── Canvas fields ───────────────────────────────────────────── */
.editor-validation {
    margin-bottom: 20px; padding: 12px 14px;
    border-radius: var(--radius);
    background: #fff5f5; border: 1px solid #f0c5c1;
    color: #c0392b; font-size: 0.88rem;
}
.editor-validation:empty { display: none; }

.editor-field-title { margin-bottom: 10px; }

.editor-input-title {
    width: 100%; border: none; outline: none;
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(1.9rem, 1.5rem + 1.2vw, 2.6rem);
    font-weight: 700; line-height: 1.15;
    color: #242424; background: transparent; padding: 0;
}
.editor-input-title::placeholder { color: #aaa; }

.editor-field-subtitle { margin-bottom: 24px; }

.editor-input-subtitle {
    width: 100%; border: none; outline: none;
    font-size: 1.1rem; line-height: 1.55;
    color: #555; background: transparent; padding: 0;
    font-family: inherit;
}
.editor-input-subtitle::placeholder { color: #aaa; }

.editor-meta-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 16px;
    margin-bottom: 24px;
}
.editor-meta-field { display: flex; flex-direction: column; gap: 4px; }
.editor-meta-field--wide { grid-column: 1 / -1; }
.editor-meta-field--check { align-self: end; padding-bottom: 4px; }

.editor-meta-label {
    font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: .06em; color: #555;
}
.editor-meta-hint { font-weight: 400; text-transform: none; letter-spacing: 0; }

.editor-meta-input {
    height: 38px; padding: 0 12px;
    border: 1px solid #c8c8c8; border-radius: var(--radius);
    background: #f5f5f5; color: #242424;
    font-size: 0.88rem; font-family: inherit;
    transition: border-color 160ms ease, background 160ms ease;
}
.editor-meta-input:focus { outline: none; border-color: #242424; background: #fff; }
.editor-meta-input::placeholder { color: #999; }

.editor-check-label {
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 0.88rem; color: var(--text); cursor: pointer; user-select: none;
}
.editor-check-input { width: 16px; height: 16px; accent-color: var(--text); cursor: pointer; }

.editor-divider { height: 1px; background: var(--line); margin-bottom: 24px; }
.editor-field-error { font-size: 0.78rem; color: #c0392b; margin-top: 3px; }

/* TinyMCE */
.editor-content-field .tox-tinymce {
    border-radius: var(--radius) !important;
    border-color: var(--line) !important;
}

/* ── AI Panel ────────────────────────────────────────────────── */
.ai-panel {
    border: 1px solid #c8c8c8;
    border-radius: 12px;
    background: #f5f5f5;
    overflow: hidden;
}

.ai-panel-header {
    display: flex; align-items: center; gap: 8px;
    padding: 12px 14px;
    background: #f2f2f2;
    border-bottom: 1px solid #d8d8d8;
    font-size: 0.75rem; font-weight: 700;
    color: #242424; text-transform: uppercase; letter-spacing: .06em;
}
.ai-panel-header i { font-size: 0.9rem; color: #242424; }

.ai-actions {
    display: flex; flex-direction: column;
    gap: 6px; padding: 12px;
}

.ai-btn {
    display: inline-flex; align-items: center; gap: 8px;
    width: 100%; height: 36px; padding: 0 12px;
    border: 1px solid #d0d0d0; border-radius: 8px;
    background: #fff; color: #242424;
    font-size: 0.82rem; font-weight: 500; font-family: inherit;
    cursor: pointer; text-align: left;
    transition: border-color 160ms ease, background 160ms ease, color 160ms ease;
    white-space: nowrap;
}
.ai-btn:hover { border-color: #242424; color: #242424; background: #f2f2f2; }
.ai-btn:disabled { opacity: 0.45; cursor: not-allowed; }
.ai-btn i { font-size: 0.78rem; width: 14px; text-align: center; color: #555; flex-shrink: 0; }

.ai-btn-primary {
    background: #242424; border-color: #242424; color: #fff;
}
.ai-btn-primary:hover { background: #111; border-color: #111; color: #fff; }
.ai-btn-primary i { color: #fff; }

/* Result box */
.ai-result {
    display: none;
    margin: 0 12px 10px;
    padding: 12px;
    background: #f5f5f5;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    font-size: 0.82rem;
    line-height: 1.6;
    color: #242424;
}
.ai-result.visible { display: block; }

#aiResultText {
    white-space: pre-wrap;
    word-break: break-word;
    margin-bottom: 10px;
    max-height: 200px;
    overflow-y: auto;
}

.ai-result-actions {
    display: flex; flex-wrap: wrap; gap: 6px;
    padding-top: 8px; border-top: 1px solid #d0d0d0;
}
.ai-result-actions .ai-btn { width: auto; }

/* Title chips */
.ai-title-chips {
    display: flex; flex-direction: column; gap: 5px;
    margin: 0 12px 10px;
}
.ai-title-chip {
    padding: 9px 12px;
    background: #f5f5f5; border: 1px solid #d0d0d0; border-radius: 8px;
    font-size: 0.82rem; font-weight: 600; cursor: pointer;
    transition: border-color 160ms ease, background 160ms ease;
    text-align: left; font-family: inherit; color: #242424;
    line-height: 1.4;
}
.ai-title-chip:hover { border-color: #242424; background: #ebebeb; }

/* Tag chips */
.ai-tag-chips {
    display: flex; flex-wrap: wrap; gap: 5px;
    margin: 0 12px 10px;
}
.ai-tag-chip {
    display: inline-flex; align-items: center; gap: 4px;
    height: 26px; padding: 0 10px;
    background: #ebebeb; border: 1px solid #c0c0c0; border-radius: 99px;
    font-size: 0.75rem; font-weight: 600; color: #242424;
    cursor: pointer; transition: background 160ms ease; font-family: inherit;
}
.ai-tag-chip:hover { background: #d8d8d8; }

/* Spinner */
.ai-spinner {
    display: none; align-items: center; gap: 8px;
    padding: 8px 12px 10px;
    font-size: 0.8rem; color: #555;
}
.ai-spinner.visible { display: flex; }

@@keyframes spin { to { transform: rotate(360deg); } }
.ai-spin-icon { animation: spin 0.8s linear infinite; font-size: 0.85rem; color: #242424; }

/* Hint text */
.ai-hint {
    margin: 4px 12px 12px;
    padding: 8px 10px;
    background: #f2f2f2;
    border-radius: 6px;
    font-size: 0.75rem;
    color: #555;
    line-height: 1.5;
}
.ai-hint i { color: #555; margin-right: 3px; }

/* Image picker */
.ai-image-section { margin: 0 12px 12px; }

.ai-image-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .05em;
    color: #555;
    margin-bottom: 8px;
}

.ai-image-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
}

.ai-image-item {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 160ms ease, transform 160ms ease;
    aspect-ratio: 16/9;
    background: #e8e8e8;
}

.ai-image-item:hover { border-color: #242424; transform: scale(1.02); }
.ai-image-item.selected { border-color: #242424; }

.ai-image-item img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
}

.ai-image-item-overlay {
    position: absolute; inset: 0;
    background: rgba(0,0,0,0);
    display: flex; align-items: center; justify-content: center;
    transition: background 160ms ease;
}

.ai-image-item:hover .ai-image-item-overlay { background: rgba(0,0,0,0.25); }

.ai-image-item-overlay i {
    color: #fff; font-size: 1.1rem;
    opacity: 0; transition: opacity 160ms ease;
}

.ai-image-item:hover .ai-image-item-overlay i { opacity: 1; }

.ai-image-kw-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: #555;
    margin: 6px 0 4px;
    grid-column: 1 / -1;
    text-transform: uppercase;
    letter-spacing: .04em;
}

.ai-image-loading {
    grid-column: 1 / -1;
    text-align: center;
    padding: 16px 0;
    font-size: 0.8rem;
    color: #888;
}

/* ── Responsive ──────────────────────────────────────────────── */
@@media (max-width: 1024px) {
    .editor-layout { grid-template-columns: 1fr; }
    .editor-canvas { padding: 32px 40px 40px; border-right: none; border-bottom: 1px solid var(--line); }
    .ai-sidebar { position: static; max-height: none; padding: 20px 40px 40px; }
    .ai-actions { flex-direction: row; flex-wrap: wrap; }
    .ai-btn { width: auto; }
}

@@media (max-width: 768px) {
    .editor-topbar { padding: 0 16px; }
    .editor-topbar-title { display: none; }
    .editor-canvas { padding: 24px 16px 32px; }
    .ai-sidebar { padding: 16px 16px 32px; }
    .editor-meta-row { grid-template-columns: 1fr; }
    .editor-meta-field--wide { grid-column: 1; }
}
</style>

<script src="https://cdn.tiny.cloud/1/81o0jisqpcft2bdbsj44ru6xu3vaw5nab39x3z4hl5h1lrrn/tinymce/6/tinymce.min.js" referrerpolicy="origin"></script>
<script>
    // ── Autosave key — unique per post (new vs editing) ───────────────────────
    const DRAFT_KEY = 'lf_draft_@(Model.Id.HasValue ? Model.Id.Value.ToString() : "new")';

    function saveDraft() {
        const editor = tinymce.get('storyEditor');
        const draft = {
            title:        document.getElementById('Title')?.value        ?? '',
            subtitle:     document.getElementById('Subtitle')?.value     ?? '',
            topic:        document.getElementById('Topic')?.value        ?? '',
            notebookId:   document.getElementById('NotebookId')?.value   ?? '',
            coverImageUrl:document.getElementById('CoverImageUrl')?.value?? '',
            excerpt:      document.getElementById('Excerpt')?.value      ?? '',
            content:      editor ? editor.getContent() : '',
            savedAt:      Date.now()
        };
        try { localStorage.setItem(DRAFT_KEY, JSON.stringify(draft)); }
        catch { /* storage full — ignore */ }
        showDraftIndicator();
    }

    function clearDraft() {
        localStorage.removeItem(DRAFT_KEY);
    }

    function showDraftIndicator() {
        const el = document.getElementById('draftIndicator');
        if (!el) return;
        el.textContent = 'Draft saved ' + new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        el.classList.add('visible');
    }

    function restoreDraft() {
        const raw = localStorage.getItem(DRAFT_KEY);
        if (!raw) return;
        try {
            const draft = JSON.parse(raw);
            // Only restore if the draft is less than 7 days old
            if (Date.now() - draft.savedAt > 7 * 24 * 60 * 60 * 1000) {
                clearDraft(); return;
            }

            const set = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
            set('Title',         draft.title);
            set('Subtitle',      draft.subtitle);
            set('Topic',         draft.topic);
            set('NotebookId',    draft.notebookId);
            set('CoverImageUrl', draft.coverImageUrl);
            set('Excerpt',       draft.excerpt);

            // TinyMCE content is restored in the setup callback after editor is ready
            window._draftContent = draft.content;

            showDraftIndicator();
        } catch { clearDraft(); }
    }

    // ── TinyMCE init ──────────────────────────────────────────────────────────
    tinymce.init({
        selector: "#storyEditor",
        height: 420,
        menubar: false,
        plugins: ["advlist","autolink","lists","link","image","table","code","codesample","fullscreen","help","wordcount","searchreplace"],
        toolbar: "undo redo | blocks | bold italic | alignleft aligncenter alignright | bullist numlist blockquote | link image table | codesample code fullscreen",
        codesample_languages: [
            { text: "HTML/XML",    value: "markup"     },
            { text: "JavaScript",  value: "javascript" },
            { text: "TypeScript",  value: "typescript" },
            { text: "CSS",         value: "css"        },
            { text: "C#",          value: "csharp"     },
            { text: "Python",      value: "python"     },
            { text: "Java",        value: "java"       },
            { text: "SQL",         value: "sql"        },
            { text: "Bash",        value: "bash"       },
            { text: "JSON",        value: "json"       },
        ],
        codesample_global_prismjs: false,
        skin: "oxide",
        content_style: "body { font-family: Georgia, 'Times New Roman', serif; font-size: 19px; line-height: 1.8; padding: 20px 28px; max-width: 100%; color: #242424; }",
        placeholder: "Tell your story…",
        toolbar_location: "top",
        toolbar_sticky: true,
        toolbar_sticky_offset: 104,
        setup: function (editor) {
            // Restore draft content once editor is ready
            editor.on('init', function () {
                if (window._draftContent) {
                    editor.setContent(window._draftContent);
                    window._draftContent = null;
                }
                // Save on every content change (debounced)
                let saveTimer;
                editor.on('input keyup change NodeChange', function () {
                    clearTimeout(saveTimer);
                    saveTimer = setTimeout(saveDraft, 1500);
                });
            });
        }
    });

    // ── Restore draft on page load ────────────────────────────────────────────
    restoreDraft();

    // ── Autosave every 10 seconds ─────────────────────────────────────────────
    setInterval(saveDraft, 10_000);

    // ── Save on plain field changes ───────────────────────────────────────────
    ['Title','Subtitle','Topic','NotebookId','CoverImageUrl','Excerpt'].forEach(id => {
        document.getElementById(id)?.addEventListener('input', saveDraft);
        document.getElementById(id)?.addEventListener('change', saveDraft);
    });

    // ── Clear draft when form is submitted ────────────────────────────────────
    document.getElementById('editorForm')?.addEventListener('submit', clearDraft);

    // ── AI helpers ────────────────────────────────────────────────────────────
    const antiForgeryToken = () =>
        document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    // Call AI endpoint directly and return the result.
    async function callAi(endpoint, text) {
        const res = await fetch(`/api/ai/${endpoint}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': antiForgeryToken()
            },
            body: JSON.stringify({ text })
        });
        if (!res.ok) throw new Error(`AI request failed: ${res.status}`);
        const data = await res.json();
        return data.result;
    }

    function getEditorText() {
        return tinymce.get('storyEditor')?.getContent({ format: 'text' }) ?? '';
    }

    function getSelectedText() {
        return tinymce.get('storyEditor')?.selection?.getContent({ format: 'text' }) ?? '';
    }

    function setLoading(loading) {
        document.querySelectorAll('.ai-btn').forEach(b => b.disabled = loading);
        const spinner = document.getElementById('aiSpinner');
        spinner?.classList.toggle('visible', loading);
        if (loading) {
            document.getElementById('aiResult')?.classList.remove('visible');
            document.getElementById('aiTitleChips')?.replaceChildren();
            document.getElementById('aiTagChips')?.replaceChildren();
        }
    }

    function showResult(text) {
        const box = document.getElementById('aiResult');
        const txt = document.getElementById('aiResultText');
        if (!box || !txt) return;
        txt.textContent = text;
        box.classList.add('visible');
        // Hide both apply buttons first
        document.getElementById('btnApplyImprove').style.display  = 'none';
        document.getElementById('btnApplyContinue').style.display = 'none';
    }

    // ── Improve selected text ─────────────────────────────────────────────────
    document.getElementById('btnImprove')?.addEventListener('click', async () => {
        const selected = getSelectedText();
        const text     = selected || getEditorText();
        if (!text.trim()) { alert('Write something first, then select text to improve (or leave nothing selected to improve all).'); return; }

        setLoading(true);
        try {
            const result = await callAi('improve', text);
            showResult(result);

            const applyBtn = document.getElementById('btnApplyImprove');
            if (applyBtn) {
                applyBtn.style.display = '';
                applyBtn.onclick = () => {
                    const editor = tinymce.get('storyEditor');
                    if (selected) {
                        editor.selection.setContent(result);
                    } else {
                        editor.setContent(result);
                    }
                    document.getElementById('aiResult')?.classList.remove('visible');
                };
            }
        } catch (e) { alert(e.message || 'AI request failed. Check your API key.'); }
        finally { setLoading(false); }
    });

    // ── Continue writing ──────────────────────────────────────────────────────
    document.getElementById('btnContinue')?.addEventListener('click', async () => {
        const text = getEditorText();
        if (!text.trim()) { alert('Write a few sentences first so AI knows what to continue.'); return; }

        setLoading(true);
        try {
            const result = await callAi('continue', text);
            showResult(result);

            const applyBtn = document.getElementById('btnApplyContinue');
            if (applyBtn) {
                applyBtn.style.display = '';
                applyBtn.onclick = () => {
                    const editor = tinymce.get('storyEditor');
                    editor.execCommand('mceInsertContent', false, '<p>' + result.replace(/\n\n/g, '</p><p>') + '</p>');
                    document.getElementById('aiResult')?.classList.remove('visible');
                };
            }
        } catch (e) { alert(e.message || 'AI request failed. Check your API key.'); }
        finally { setLoading(false); }
    });

    // ── Auto-fill excerpt ─────────────────────────────────────────────────────
    document.getElementById('btnSummarize')?.addEventListener('click', async () => {
        const text = getEditorText();
        if (!text.trim()) { alert('Write some content first.'); return; }

        setLoading(true);
        try {
            const result = await callAi('summarize', text);
            const excerptInput = document.getElementById('Excerpt');
            if (excerptInput) {
                excerptInput.value = result;
                excerptInput.focus();
            }
        } catch (e) { alert(e.message || 'AI request failed. Check your API key.'); }
        finally { setLoading(false); }
    });

    // ── Suggest titles ────────────────────────────────────────────────────────
    document.getElementById('btnSuggestTitle')?.addEventListener('click', async () => {
        const text = getEditorText();
        if (!text.trim()) { alert('Write some content first.'); return; }

        setLoading(true);
        try {
            const raw    = await callAi('suggest-title', text);
            const titles = JSON.parse(raw);   // result is a JSON array string
            const chips  = document.getElementById('aiTitleChips');
            if (!chips) return;
            chips.replaceChildren();
            titles.forEach(title => {
                const btn = document.createElement('button');
                btn.type      = 'button';
                btn.className = 'ai-title-chip';
                btn.textContent = title;
                btn.onclick = () => {
                    document.getElementById('Title').value = title;
                    chips.replaceChildren();
                };
                chips.appendChild(btn);
            });
        } catch (e) { alert(e.message || 'AI request failed. Check your API key.'); }
        finally { setLoading(false); }
    });

    // ── Suggest tags ──────────────────────────────────────────────────────────
    document.getElementById('btnSuggestTags')?.addEventListener('click', async () => {
        const text = getEditorText();
        if (!text.trim()) { alert('Write some content first.'); return; }

        setLoading(true);
        try {
            const raw  = await callAi('suggest-tags', text);
            const tags = JSON.parse(raw);   // result is a JSON array string
            const chips = document.getElementById('aiTagChips');
            if (!chips) return;
            chips.replaceChildren();
            tags.forEach(tag => {
                const btn = document.createElement('button');
                btn.type      = 'button';
                btn.className = 'ai-tag-chip';
                btn.innerHTML = `<i class="fas fa-plus"></i> ${tag}`;
                btn.onclick = () => {
                    const topicInput = document.getElementById('Topic');
                    const current    = topicInput.value.trim();
                    topicInput.value = current ? `${current}, ${tag}` : tag;
                    btn.remove();
                };
                chips.appendChild(btn);
            });
        } catch (e) { alert(e.message || 'AI request failed. Check your API key.'); }
        finally { setLoading(false); }
    });

    // ── Suggest cover images ──────────────────────────────────────────────────
    document.getElementById('btnSuggestImages')?.addEventListener('click', async () => {
        const text = getEditorText() || document.getElementById('Title')?.value || '';
        if (!text.trim()) { alert('Write some content or a title first so AI knows what to search for.'); return; }

        const section = document.getElementById('aiImageSection');
        const grid    = document.getElementById('aiImageGrid');
        const label   = document.getElementById('aiImageLabel');

        setLoading(true);
        section.style.display = 'none';
        grid.replaceChildren();

        try {
            const result = await callAi('suggest-images', text);
            const images = Array.isArray(result) ? result : JSON.parse(result);

            section.style.display = '';
            label.textContent     = 'Click an image to use it as cover';

            grid.replaceChildren();
            images.forEach((img, idx) => {
                // Add keyword label before first image of each keyword
                if (idx % 2 === 0) {
                    const kwLabel = document.createElement('div');
                    kwLabel.className   = 'ai-image-kw-label';
                    kwLabel.textContent = img.keyword;
                    grid.appendChild(kwLabel);
                }

                const item = document.createElement('div');
                item.className = 'ai-image-item';

                const image = document.createElement('img');
                image.src     = img.src || img.thumbUrl;
                image.alt     = img.alt || img.keyword;
                image.loading = 'lazy';

                const overlay = document.createElement('div');
                overlay.className = 'ai-image-item-overlay';
                overlay.innerHTML = '<i class="fas fa-check-circle"></i>';

                item.appendChild(image);
                item.appendChild(overlay);

                item.addEventListener('click', () => {
                    const coverInput = document.getElementById('CoverImageUrl');
                    if (coverInput) {
                        coverInput.value = img.src || img.url;
                        coverInput.focus();
                        grid.querySelectorAll('.ai-image-item').forEach(el => el.classList.remove('selected'));
                        item.classList.add('selected');
                        coverInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                });

                grid.appendChild(item);
            });

        } catch (e) { alert(e.message || 'AI request failed. Check your API key.'); }
        finally { setLoading(false); }
    });
</script>
}
