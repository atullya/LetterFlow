@model LetterTemplatePractice.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = $"{Model.User.DisplayName ?? Model.User.Username} – LetterFlow";
    ViewData["MetaDescription"] = $"View {Model.User.DisplayName ?? Model.User.Username}'s profile on LetterFlow Stories. {Model.Posts.Count} published stories.";
    var user = Model.User;
    var profileName = user.DisplayName ?? user.Username;
    ViewData["Title"] = $"{profileName} Profile";
    ViewData["MetaDescription"] = $"View {profileName}'s LetterFlow Stories profile, published newsletters, follower counts, and professional writing activity.";
}

<div class="feed-layout">
    <main class="feed-main" style="padding-top:32px;">

        @* ── Profile Header ── *@
        <div class="profile-header">
            <div class="profile-avatar-lg">
                @if (!string.IsNullOrWhiteSpace(user.AvatarUrl))
                {
                    <img src="@user.AvatarUrl" alt="@user.DisplayName" />
                }
                else
                {
                    @((user.DisplayName ?? user.Username ?? "?").Substring(0, 1).ToUpper())
                }
            </div>

            <h1 class="profile-name">@(user.DisplayName ?? user.Username)</h1>
            @if (user.DisplayName != null && user.Username != null)
            {
                <div class="profile-username">@@@user.Username</div>
            }
            <div class="profile-member-since">Member since @user.CreatedAt.ToString("MMMM yyyy")</div>

            <div class="profile-stats">
                <a href="@Url.Action("Followers", "Blog", new { username = user.Username })" class="profile-stat-link">
                    <strong id="follower-count-@user.Id">@Model.FollowerCount</strong> followers
                </a>
                <span class="profile-stat-sep">&middot;</span>
                <a href="@Url.Action("Following", "Blog", new { username = user.Username })" class="profile-stat-link">
                    <strong>@Model.FollowingCount</strong> following
                </a>
            </div>

            @if (!Model.IsOwnProfile && User.Identity?.IsAuthenticated == true)
            {
                <div class="profile-actions-row">
                    <button type="button"
                            class="btn-follow @(Model.IsFollowing ? "btn-following" : "")"
                            data-user-id="@user.Id"
                            data-url="@Url.Action("ToggleFollow", "Blog", new { userId = user.Id })">
                        @(Model.IsFollowing ? "Following" : "Follow")
                    </button>

                    <button type="button"
                            class="btn-report-user"
                            data-user-id="@user.Id"
                            data-username="@user.Username"
                            onclick="openReportUserModal(@user.Id, '@user.Username')">
                        <i class="fas fa-flag"></i> Report
                    </button>
                </div>
            }
        </div>

        @* ── User's Posts ── *@
        <div class="profile-section-title" style="margin-top:32px; padding-bottom:12px; border-bottom:1px solid var(--line);">
            <h2 style="font-weight:700; font-size:1rem; margin:0;">Stories</h2>
        </div>

        @if (!Model.Posts.Any())
        {
            <div style="text-align:center; padding:48px 0; color:var(--muted);">
                <i class="fa-regular fa-file-lines" style="font-size:2rem; margin-bottom:8px; display:block;"></i>
                No stories yet.
            </div>
        }
        else
        {
            @foreach (var post in Model.Posts)
            {
                await Html.RenderPartialAsync("_StoryCard", post);
            }
        }

    </main>

    <aside class="feed-rail">
        <div class="rail-box" style="padding:16px;">
            <h2 style="font-weight:700; margin-bottom:12px; font-size:1rem;">About</h2>
            <div style="font-size:0.88rem; color:var(--muted); line-height:1.5;">
                @(user.DisplayName ?? user.Username) has published @Model.Posts.Count stories on LetterFlow.
            </div>
        </div>
    </aside>
</div>

@* ── Report User Modal ── *@
@if (User.Identity?.IsAuthenticated == true && !Model.IsOwnProfile)
{
    <div id="reportUserModal" class="report-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="reportModalTitle">
        <div class="report-modal">
            <div class="report-modal-header">
                <h2 class="report-modal-title" id="reportModalTitle">
                    <i class="fas fa-flag" style="color:#dc2626;margin-right:8px;"></i>
                    Report user
                </h2>
                <button type="button" class="report-modal-close" onclick="closeReportUserModal()" aria-label="Close">&times;</button>
            </div>
            <form method="post" asp-controller="Blog" asp-action="ReportUser" id="reportUserForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" id="reportUserId" value="@user.Id" />
                <div class="report-modal-body">
                    <p class="report-modal-desc">
                        Reporting <strong id="reportTargetName">@@@user.Username</strong>.
                        Your report is anonymous and will be reviewed by our team.
                    </p>
                    <label class="report-label" for="reportUserReason">Reason <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
                    <textarea id="reportUserReason" name="reason" rows="4"
                              class="report-textarea"
                              maxlength="500"
                              placeholder="Describe why you're reporting this user…"></textarea>
                    <div class="report-char-count"><span id="reportUserCharCount">0</span> / 500</div>
                </div>
                <div class="report-modal-footer">
                    <button type="button" class="btn btn-secondary" onclick="closeReportUserModal()">Cancel</button>
                    <button type="submit" class="btn btn-danger-report">Submit report</button>
                </div>
            </form>
        </div>
    </div>
}

@section Scripts {
<style>
/* ── Profile action row ── */
.profile-actions-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
    flex-wrap: wrap;
    justify-content: center;
}

.btn-report-user {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 16px;
    border: 1px solid #fca5a5;
    border-radius: 999px;
    background: transparent;
    color: #dc2626;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 140ms, border-color 140ms;
}

.btn-report-user:hover {
    background: #fee2e2;
    border-color: #dc2626;
}

/* ── Report modal ── */
.report-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 16px;
}

.report-modal-backdrop.is-open {
    display: flex;
}

.report-modal {
    background: #fff;
    border-radius: 14px;
    width: 100%;
    max-width: 460px;
    box-shadow: 0 20px 60px rgba(0,0,0,.18);
    overflow: hidden;
    animation: modalIn 180ms ease;
}

@@keyframes modalIn {
    from { opacity: 0; transform: translateY(12px) scale(.97); }
    to   { opacity: 1; transform: none; }
}

.report-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px 14px;
    border-bottom: 1px solid var(--line, #e5e5e5);
}

.report-modal-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
}

.report-modal-close {
    background: none;
    border: none;
    font-size: 1.4rem;
    line-height: 1;
    color: var(--muted, #888);
    cursor: pointer;
    padding: 0 4px;
}

.report-modal-close:hover { color: var(--text, #111); }

.report-modal-body { padding: 18px 20px; }

.report-modal-desc {
    font-size: 0.875rem;
    color: var(--muted, #666);
    margin: 0 0 14px;
    line-height: 1.5;
}

.report-label {
    display: block;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 6px;
}

.report-textarea {
    width: 100%;
    border: 1px solid var(--line, #e5e5e5);
    border-radius: 8px;
    padding: 10px 12px;
    font-size: 0.875rem;
    resize: vertical;
    font-family: inherit;
    transition: border-color 140ms;
    box-sizing: border-box;
}

.report-textarea:focus {
    outline: none;
    border-color: #dc2626;
}

.report-char-count {
    text-align: right;
    font-size: 0.75rem;
    color: var(--muted, #888);
    margin-top: 4px;
}

.report-modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    padding: 14px 20px 18px;
    border-top: 1px solid var(--line, #e5e5e5);
}

.btn-danger-report {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 140ms;
}

.btn-danger-report:hover { background: #b91c1c; }
</style>

<script>
function openReportUserModal(userId, username) {
    document.getElementById('reportUserId').value = userId;
    document.getElementById('reportTargetName').textContent = '@@' + username;
    document.getElementById('reportUserReason').value = '';
    document.getElementById('reportUserCharCount').textContent = '0';
    const modal = document.getElementById('reportUserModal');
    modal.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    document.getElementById('reportUserReason').focus();
}

function closeReportUserModal() {
    document.getElementById('reportUserModal').classList.remove('is-open');
    document.body.style.overflow = '';
}

// Close on backdrop click
document.getElementById('reportUserModal')?.addEventListener('click', function (e) {
    if (e.target === this) closeReportUserModal();
});

// Close on Escape
document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') closeReportUserModal();
});

// Character counter
document.getElementById('reportUserReason')?.addEventListener('input', function () {
    document.getElementById('reportUserCharCount').textContent = this.value.length;
});
</script>
}
