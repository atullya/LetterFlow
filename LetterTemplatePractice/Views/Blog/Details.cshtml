@model LetterTemplatePractice.Models.ViewModels.BlogDetailsViewModel
@{
    ViewData["Title"] = Model.Post.Title;
    ViewData["MetaDescription"] = Model.Post.Excerpt ?? $"Read \"{Model.Post.Title}\" on LetterFlow Stories. {Model.Post.ReadTimeMinutes} min read.";
    ViewData["BodyClass"] = "reader-mode";
    if (!string.IsNullOrWhiteSpace(Model.Post.CoverImageUrl))
    {
        ViewData["OgImage"] = Model.Post.CoverImageUrl;
    }
    var absoluteUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/stories/{Model.Post.Slug}";
}

<article class="article-shell">
    <header class="article-header">
        <div class="article-kicker">@Model.Post.Topic</div>
        <h1 class="article-title">@Model.Post.Title</h1>
        @if (!string.IsNullOrWhiteSpace(Model.Post.Subtitle))
        {
            <p class="article-subtitle">@Model.Post.Subtitle</p>
        }
        <div class="article-meta-bar">
            <div class="article-author-lockup">
                <div class="article-author-avatar">@(Model.Post.Author?.Username?.Substring(0, 1).ToUpper() ?? "?")</div>
                <div>
                    <div class="article-author-name">@Model.Post.Author?.Username</div>
                    <div class="article-meta">
                        <span>@(Model.Post.PublishedAt?.ToString("MMM dd, yyyy") ?? Model.Post.UpdatedAt.ToString("MMM dd, yyyy"))</span>
                        <span>@Model.Post.ReadTimeMinutes min read</span>
                        <span>@Model.Post.ViewCount views</span>
                    </div>
                </div>
            </div>
            @if (Model.IsOwner)
            {
                <div class="article-owner-actions">
                    <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="btn btn-secondary btn-sm">Edit story</a>
                </div>
            }
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(Model.Post.CoverImageUrl))
    {
        <img class="article-cover" src="@Model.Post.CoverImageUrl" alt="@Model.Post.Title" />
    }

    <section class="article-toolbar">
        <div class="article-action-row">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <form id="likeForm" asp-action="ToggleLike" asp-route-id="@Model.Post.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" id="likeButton" class="article-action-button @(Model.IsLikedByCurrentUser ? "liked" : string.Empty)">
                        <i class="fas fa-heart"></i>
                        <span><span id="likeCount">@Model.Post.Likes.Count</span> clap@(Model.Post.Likes.Count == 1 ? "" : "s")</span>
                    </button>
                </form>
            }
            else
            {
                <a asp-controller="Account" asp-action="Login" class="article-action-button">
                    <i class="fas fa-heart"></i>
                    <span>@Model.Post.Likes.Count clap@(Model.Post.Likes.Count == 1 ? "" : "s")</span>
                </a>
            }
            <a href="#discussion" class="article-action-button">
                <i class="fas fa-comment"></i>
                <span>@Model.Comments.Count comment@(Model.Comments.Count == 1 ? "" : "s")</span>
            </a>
            <button type="button" id="copyShareButton" class="article-action-button" data-url="@absoluteUrl">
                <i class="fas fa-link"></i>
                <span>Copy link</span>
            </button>
            <a class="article-action-button" href="https://twitter.com/intent/tweet?url=@Uri.EscapeDataString(absoluteUrl)&text=@Uri.EscapeDataString(Model.Post.Title)" target="_blank" rel="noopener noreferrer">
                <i class="fab fa-x-twitter"></i>
                <span>Share</span>
            </a>
            @if (User.Identity?.IsAuthenticated == true && !Model.IsOwner)
            {
                <button type="button"
                        class="article-action-button article-action-report"
                        onclick="openReportPostModal(@Model.Post.Id, '@Html.Raw(Html.Encode(Model.Post.Title))')">
                    <i class="fas fa-flag"></i>
                    <span>Report</span>
                </button>
            }
        </div>
    </section>

    <section class="article-body" id="articleContent">
        @Html.Raw(Model.Post.ContentHtml)
    </section>

    <section class="article-toolbar article-toolbar-bottom">
        <div class="article-action-summary">
            <span>@Model.Post.Likes.Count clap@(Model.Post.Likes.Count == 1 ? "" : "s")</span>
            <span>@Model.Comments.Count comment@(Model.Comments.Count == 1 ? "" : "s")</span>
        </div>
    </section>

    <section class="author-card">
        <div class="article-author-avatar article-author-avatar-lg">@(Model.Post.Author?.Username?.Substring(0, 1).ToUpper() ?? "?")</div>
        <div class="author-card-copy">
            <p class="author-card-label">Written by</p>
            <h2>@Model.Post.Author?.Username</h2>
            <p>@(string.IsNullOrWhiteSpace(Model.Post.Subtitle) ? "Publishing thoughtful stories for readers who want a slower, clearer page." : Model.Post.Subtitle)</p>
        </div>
    </section>

    <section class="reader-secondary-block" id="discussion">
        <div class="reader-section-heading">
            <h2>Responses</h2>
            <p>@Model.Comments.Count comment@(Model.Comments.Count == 1 ? "" : "s") on this story.</p>
        </div>

        @if (Model.CanComment)
        {
            <form asp-action="AddComment" asp-route-id="@Model.Post.Id" method="post" class="stack-sm reader-comment-form">
                @Html.AntiForgeryToken()
                <textarea name="content" rows="4" class="form-control" placeholder="Write a response"></textarea>
                <div>
                    <button type="submit" class="btn btn-primary btn-sm">Post comment</button>
                </div>
            </form>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-circle-info"></i>
                <div>Sign in to comment, clap, and join the discussion.</div>
            </div>
        }

        <div class="stack-sm">
            @if (!Model.Comments.Any())
            {
                <div class="empty-state empty-state-compact">
                    <i class="fas fa-comment-dots"></i>
                    <h3>No comments yet</h3>
                    <p>Be the first reader to respond.</p>
                </div>
            }
            else
            {
                @foreach (var comment in Model.Comments)
                {
                    <article class="comment-card">
                        <div class="comment-card-meta">
                            <strong>@comment.Author?.Username</strong>
                            <span>@comment.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</span>
                        </div>
                        <div class="comment-card-body">@comment.Content</div>
                        @if ((User.Identity?.IsAuthenticated == true) &&
                             (User.Identity?.Name == comment.Author?.Username || Model.IsOwner || User.IsInRole(UserRoles.Admin)))
                        {
                            <form asp-action="DeleteComment" asp-route-id="@comment.Id" method="post" style="margin-top:12px">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                            </form>
                        }
                    </article>
                }
            }
        </div>
    </section>

    @if (Model.RelatedPosts.Any())
    {
        <section class="reader-secondary-block">
            <div class="reader-section-heading">
                <h2>More from this publication</h2>
            </div>
            <div class="stack-sm">
                @foreach (var related in Model.RelatedPosts)
                {
                    <a asp-action="Details" asp-route-slug="@related.Slug" class="compact-story-link">
                        <div class="compact-story-title">@related.Title</div>
                        <div class="compact-story-meta">@related.Author?.Username - @related.ReadTimeMinutes min read</div>
                    </a>
                }
            </div>
        </section>
    }

    <section class="reader-secondary-block">
        <div class="reader-section-heading">
            <h2>Writing resources</h2>
        </div>
        <a href="https://blog.hubspot.com/marketing/newsletter-tips"
           target="_blank"
           rel="noopener noreferrer"
           class="compact-story-link">Newsletter Best Practices</a>
    </section>
</article>

@section Scripts {
    @* ── Report Post Modal ── *@
    @if (User.Identity?.IsAuthenticated == true && !Model.IsOwner)
    {
        <div id="reportPostModal" class="report-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="reportPostModalTitle">
            <div class="report-modal">
                <div class="report-modal-header">
                    <h2 class="report-modal-title" id="reportPostModalTitle">
                        <i class="fas fa-flag" style="color:#dc2626;margin-right:8px;"></i>
                        Report story
                    </h2>
                    <button type="button" class="report-modal-close" onclick="closeReportPostModal()" aria-label="Close">&times;</button>
                </div>
                <form method="post" asp-controller="Blog" asp-action="ReportPost" id="reportPostForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="reportPostId" value="@Model.Post.Id" />
                    <div class="report-modal-body">
                        <p class="report-modal-desc">
                            Reporting <strong id="reportPostTitle">@Model.Post.Title</strong>.
                            Your report is anonymous and will be reviewed by our team.
                        </p>
                        <label class="report-label" for="reportPostReason">Reason <span style="color:var(--muted);font-weight:400;">(optional)</span></label>
                        <textarea id="reportPostReason" name="reason" rows="4"
                                  class="report-textarea"
                                  maxlength="500"
                                  placeholder="Describe why you're reporting this story…"></textarea>
                        <div class="report-char-count"><span id="reportPostCharCount">0</span> / 500</div>
                    </div>
                    <div class="report-modal-footer">
                        <button type="button" class="btn btn-secondary" onclick="closeReportPostModal()">Cancel</button>
                        <button type="submit" class="btn-danger-report">Submit report</button>
                    </div>
                </form>
            </div>
        </div>
    }

    <!-- Prism.js for codesample syntax highlighting -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-core.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/plugins/autoloader/prism-autoloader.min.js"></script>
    <script>
        const likeForm = document.getElementById("likeForm");
        const likeButton = document.getElementById("likeButton");
        const likeCount = document.getElementById("likeCount");

        if (likeForm && likeButton && likeCount) {
            likeForm.addEventListener("submit", async function (event) {
                event.preventDefault();

                const response = await fetch(this.action, {
                    method: "POST",
                    headers: {
                        "RequestVerificationToken": this.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                if (!response.ok) {
                    return;
                }

                const result = await response.json();
                likeCount.textContent = result.count;
                likeButton.classList.toggle("liked", result.liked);
            });
        }

        document.getElementById("copyShareButton")?.addEventListener("click", async function () {
            const url = this.dataset.url;
            await navigator.clipboard.writeText(url);
            this.querySelector("span").textContent = "Copied";
            setTimeout(() => {
                this.querySelector("span").textContent = "Copy link";
            }, 1800);
        });


        document.querySelectorAll('.article-body pre').forEach(pre => {
            // wrap in a relative container
            const wrapper = document.createElement('div');
            wrapper.className = 'code-block-wrap';
            pre.parentNode.insertBefore(wrapper, pre);
            wrapper.appendChild(pre);

            const btn = document.createElement('button');
            btn.className   = 'code-copy-btn';
            btn.type        = 'button';
            btn.title       = 'Copy code';
            btn.innerHTML   = '<i class="far fa-copy"></i>';
            wrapper.appendChild(btn);

            btn.addEventListener('click', async () => {
                const code = pre.querySelector('code')?.innerText ?? pre.innerText;
                await navigator.clipboard.writeText(code);
                btn.innerHTML = '<i class="fas fa-check"></i>';
                btn.classList.add('copied');
                setTimeout(() => {
                    btn.innerHTML = '<i class="far fa-copy"></i>';
                    btn.classList.remove('copied');
                }, 2000);
            });
        });

        // ── Report Post modal ──────────────────────────────────────────────
        function openReportPostModal(postId, title) {
            document.getElementById('reportPostId').value = postId;
            document.getElementById('reportPostTitle').textContent = title;
            document.getElementById('reportPostReason').value = '';
            document.getElementById('reportPostCharCount').textContent = '0';
            const modal = document.getElementById('reportPostModal');
            modal.classList.add('is-open');
            document.body.style.overflow = 'hidden';
            document.getElementById('reportPostReason').focus();
        }

        function closeReportPostModal() {
            document.getElementById('reportPostModal').classList.remove('is-open');
            document.body.style.overflow = '';
        }

        document.getElementById('reportPostModal')?.addEventListener('click', function (e) {
            if (e.target === this) closeReportPostModal();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') closeReportPostModal();
        });

        document.getElementById('reportPostReason')?.addEventListener('input', function () {
            document.getElementById('reportPostCharCount').textContent = this.value.length;
        });
    </script>

    <style>
        /* ── Report button in toolbar ── */
        .article-action-report { color: #dc2626 !important; }
        .article-action-report:hover { background: #fee2e2 !important; }

        /* ── Report modal (shared with Profile) ── */
        .report-modal-backdrop {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.45);
            z-index: 1000;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 16px;
        }

        .report-modal-backdrop.is-open {
            display: flex;
        }

        .report-modal {
            background: #fff;
            border-radius: 14px;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 20px 60px rgba(0,0,0,.18);
            overflow: hidden;
            animation: modalIn 180ms ease;
        }

        @@keyframes modalIn {
            from { opacity: 0; transform: translateY(12px) scale(.97); }
            to   { opacity: 1; transform: none; }
        }

        .report-modal-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 20px 14px;
            border-bottom: 1px solid var(--line, #e5e5e5);
        }

        .report-modal-title {
            font-size: 1rem;
            font-weight: 700;
            margin: 0;
        }

        .report-modal-close {
            background: none;
            border: none;
            font-size: 1.4rem;
            line-height: 1;
            color: var(--muted, #888);
            cursor: pointer;
            padding: 0 4px;
        }

        .report-modal-close:hover { color: var(--text, #111); }

        .report-modal-body { padding: 18px 20px; }

        .report-modal-desc {
            font-size: 0.875rem;
            color: var(--muted, #666);
            margin: 0 0 14px;
            line-height: 1.5;
        }

        .report-label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            margin-bottom: 6px;
        }

        .report-textarea {
            width: 100%;
            border: 1px solid var(--line, #e5e5e5);
            border-radius: 8px;
            padding: 10px 12px;
            font-size: 0.875rem;
            resize: vertical;
            font-family: inherit;
            transition: border-color 140ms;
            box-sizing: border-box;
        }

        .report-textarea:focus {
            outline: none;
            border-color: #dc2626;
        }

        .report-char-count {
            text-align: right;
            font-size: 0.75rem;
            color: var(--muted, #888);
            margin-top: 4px;
        }

        .report-modal-footer {
            display: flex;
            justify-content: flex-end;
            gap: 8px;
            padding: 14px 20px 18px;
            border-top: 1px solid var(--line, #e5e5e5);
        }

        .btn-danger-report {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 8px 18px;
            background: #dc2626;
            color: #fff;
            border: none;
            border-radius: 6px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 140ms;
        }

        .btn-danger-report:hover { background: #b91c1c; }
    </style>
}

@{
    var schemaImage = !string.IsNullOrWhiteSpace(Model.Post.CoverImageUrl)
        ? $",\n  \"image\": \"{Model.Post.CoverImageUrl}\""
        : "";
}
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "Article",
  "headline": "@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Post.Title).Trim('"'))",
  "description": "@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Post.Excerpt ?? Model.Post.Subtitle ?? Model.Post.Title).Trim('"'))",
  "author": {
    "@@type": "Person",
    "name": "@(Model.Post.Author?.DisplayName ?? Model.Post.Author?.Username ?? "LetterFlow")"
  },
  "publisher": {
    "@@type": "Organization",
    "name": "LetterFlow Stories",
    "url": "https://letterflow-ps3k.onrender.com"
  },
  "url": "@absoluteUrl",
  "datePublished": "@(Model.Post.PublishedAt?.ToString("yyyy-MM-dd") ?? Model.Post.CreatedAt.ToString("yyyy-MM-dd"))",
  "dateModified": "@Model.Post.UpdatedAt.ToString("yyyy-MM-dd")"@Html.Raw(schemaImage)
}
</script>
